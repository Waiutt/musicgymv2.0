<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical">

    <!-- 顶部栏 -->
    <LinearLayout style="@style/TopBar">

        <TextView
            android:id="@+id/sworkout_btn_back"
            style="@style/CloseButton" />

        <TextView
            style="@style/ToolbarTitle"
            android:text="训练记录" />

        <TextView
            android:id="@+id/sworkout_toggle_mode"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/stats_filter_unselected"
            android:gravity="center"
            android:text="◉"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/sworkout_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="@color/accent_amber"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- 列表模式 -->
        <ScrollView
            android:id="@+id/sworkout_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/sworkout_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp" />
        </ScrollView>

        <!-- 滑动切换模式 -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/sworkout_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- 组间休息浮层 -->
        <LinearLayout
            android:id="@+id/sworkout_rest_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_overlay"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱"
                android:textSize="48sp" />

            <TextView
                android:id="@+id/sworkout_rest_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="休息 01:30"
                android:textColor="@color/accent_amber"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="点击跳过"
                android:textColor="@color/text_gray"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/sworkout_rest_duration_btns"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/rest_dur_60"
                    android:layout_width="42dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@color/bg_input"
                    android:gravity="center"
                    android:text="60s"
                    android:textColor="@color/text_gray_light"
                    android:textSize="11sp"
                    android:clickable="true" />

                <TextView
                    android:id="@+id/rest_dur_90"
                    android:layout_width="42dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@color/brand_orange"
                    android:gravity="center"
                    android:text="90s"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:clickable="true" />

                <TextView
                    android:id="@+id/rest_dur_120"
                    android:layout_width="42dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@color/bg_input"
                    android:gravity="center"
                    android:text="120s"
                    android:textColor="@color/text_gray_light"
                    android:textSize="11sp"
                    android:clickable="true" />

                <TextView
                    android:id="@+id/rest_dur_180"
                    android:layout_width="42dp"
                    android:layout_height="32dp"
                    android:background="@color/bg_input"
                    android:gravity="center"
                    android:text="180s"
                    android:textColor="@color/text_gray_light"
                    android:textSize="11sp"
                    android:clickable="true" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- 底部保存 -->
    <TextView
        android:id="@+id/sworkout_btn_save"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:background="@color/brand_orange"
        android:gravity="center"
        android:text="保存训练"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
