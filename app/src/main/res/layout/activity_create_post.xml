<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UPLOAD NEW DATA"
        android:textColor="@color/cyber_cyan"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <ImageView
        android:id="@+id/create_iv_preview"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@color/bg_card"
        android:scaleType="centerCrop"
        android:layout_marginBottom="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/create_btn_camera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CAMERA"
            android:backgroundTint="@color/cyber_rose"
            android:layout_marginEnd="5dp"/>

        <Button
            android:id="@+id/create_btn_gallery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GALLERY"
            android:backgroundTint="@color/accent_purple"
            android:layout_marginStart="5dp"/>
    </LinearLayout>

    <EditText
        android:id="@+id/create_et_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Transmission Title"
        android:textColorHint="@color/text_gray_mid"
        android:textColor="@color/white"
        android:backgroundTint="@color/cyber_cyan"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/create_et_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="top"
        android:hint="Enter log details..."
        android:textColorHint="@color/text_gray_mid"
        android:textColor="@color/white"
        android:backgroundTint="@color/cyber_cyan"/>

    <Button
        android:id="@+id/create_btn_publish"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="INITIATE UPLOAD"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="@color/accent_emerald"
        android:layout_marginTop="20dp"/>

</LinearLayout>