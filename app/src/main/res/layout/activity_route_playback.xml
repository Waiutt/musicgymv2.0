<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <com.amap.api.maps.MapView
        android:id="@+id/route_map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 顶栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/route_btn_back"
            style="@style/CloseButton" />

        <TextView
            android:id="@+id/route_btn_satellite"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/stats_filter_unselected"
            android:gravity="center"
            android:text="🛰"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/route_tv_title"
            style="@style/ToolbarTitle"
            android:text="路线回放" />

        <TextView
            android:id="@+id/route_btn_play"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@color/brand_orange"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="▶ 播放"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 底部信息 -->
    <LinearLayout
        android:id="@+id/route_info_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#cc0f172a"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/route_info_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="总距离 0.00 km | 时长 00:00"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>
</FrameLayout>
