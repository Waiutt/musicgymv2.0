<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a"
    android:orientation="vertical">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1e293b"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/strength_btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/stats_filter_unselected"
            android:gravity="center"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="力量训练"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/strength_selected_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已选 0 项"
            android:textColor="#FC4C02"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 部位标签 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#1e293b"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/strength_tab_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </HorizontalScrollView>

    <!-- 搜索栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#1e293b"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <EditText
            android:id="@+id/strength_search"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="#334155"
            android:hint="搜索动作..."
            android:textColorHint="#6b7280"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/strength_btn_template"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="#334155"
            android:gravity="center"
            android:text="📋"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 动作列表 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/strength_exercise_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />
    </ScrollView>

    <!-- 底部操作栏 -->
    <LinearLayout
        android:id="@+id/strength_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1e293b"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/strength_bottom_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 个动作已选"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/strength_btn_start"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="#FC4C02"
            android:gravity="center"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:text="开始训练"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
