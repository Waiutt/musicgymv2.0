<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a">

    <!-- 全屏地图 -->
    <com.amap.api.maps.MapView
        android:id="@+id/workout_mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#cc0f172a"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/workout_btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/stats_filter_unselected"
            android:gravity="center"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/workout_sport_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="跑步"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/workout_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#22c55e"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 底部仪表盘 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="100dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <!-- 距离 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/workout_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="公里"
                android:textColor="#94a3b8"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 卡路里 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/workout_calories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#f59e0b"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="千卡"
                android:textColor="#94a3b8"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 配速 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/workout_pace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0'00''"
                android:textColor="#38bdf8"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="配速"
                android:textColor="#94a3b8"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 开始 / 暂停按钮 -->
    <TextView
        android:id="@+id/workout_btn_action"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/workout_btn_start"
        android:gravity="center"
        android:text="GO"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 暂停浮层 -->
    <FrameLayout
        android:id="@+id/workout_pause_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#cc0f172a"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸"
                android:textSize="64sp" />

            <TextView
                android:id="@+id/workout_pause_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="运动已暂停"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/workout_btn_resume"
                    android:layout_width="100dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="16dp"
                    android:background="#22c55e"
                    android:gravity="center"
                    android:text="继续"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/workout_btn_stop"
                    android:layout_width="100dp"
                    android:layout_height="48dp"
                    android:background="#ef4444"
                    android:gravity="center"
                    android:text="结束"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
