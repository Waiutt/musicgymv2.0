<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- ═══ 顶部工具栏 ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/music_title"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/music_btn_shuffle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/stats_filter_unselected"
            android:gravity="center"
            android:text="🔀"
            android:textSize="14sp"
            android:contentDescription="@string/music_mode_shuffle" />

        <TextView
            android:id="@+id/music_mode_label"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:text="@string/music_mode_sequential"
            android:textColor="@color/text_gray"
            android:textSize="11sp"
            android:paddingStart="4dp"
            android:paddingEnd="8dp" />

        <TextView
            android:id="@+id/music_btn_eq"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/stats_filter_unselected"
            android:gravity="center"
            android:text="🎚"
            android:textSize="14sp"
            android:contentDescription="均衡器" />

        <TextView
            android:id="@+id/music_btn_rescan"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/stats_filter_unselected"
            android:gravity="center"
            android:text="🔄"
            android:textSize="14sp"
            android:contentDescription="重新扫描" />
    </LinearLayout>

    <!-- ═══ 播放器区域 ═══ -->
    <LinearLayout
        android:id="@+id/music_player_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <androidx.cardview.widget.CardView
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="90dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@color/bg_card">

            <ImageView
                android:id="@+id/music_iv_album"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/music_tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/music_not_playing"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/music_btn_favorite"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:text="🤍"
                android:textSize="16sp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="收藏歌曲" />
        </LinearLayout>

        <TextView
            android:id="@+id/music_tv_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/music_scanning"
            android:textColor="@color/text_gray"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="4dp"
            android:gravity="center" />

        <!-- 进度条 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/music_tv_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/cyber_cyan"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/music_seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:progressTint="@color/cyber_rose"
                android:thumbTint="@color/cyber_rose" />

            <TextView
                android:id="@+id/music_tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_gray_mid"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 控制按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <ImageButton
                android:id="@+id/music_btn_prev"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="上一首"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/music_btn_play"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_play"
                android:scaleX="1.6"
                android:scaleY="1.6"
                android:contentDescription="播放/暂停"
                app:tint="@color/accent_emerald" />

            <ImageButton
                android:id="@+id/music_btn_next"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="下一首"
                app:tint="@color/white" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ 底部固定迷你播放条 ═══ -->
    <FrameLayout
        android:id="@+id/music_mini_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_panel"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/music_mini_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="未在播放"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/music_mini_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_gray"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/music_mini_play"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_play"
                android:scaleX="1.2"
                android:scaleY="1.2"
                app:tint="@color/accent_emerald"
                android:contentDescription="播放/暂停" />
        </LinearLayout>
    </FrameLayout>

    <!-- ═══ 歌列表面板 ═══ -->
    <LinearLayout
        android:id="@+id/music_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/bg_panel">

        <!-- 拖动把手 -->
        <LinearLayout
            android:id="@+id/music_drag_handle"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="#00000000"
            android:contentDescription="拖动调整歌单">

            <View
                android:layout_width="36dp"
                android:layout_height="5dp"
                android:background="@drawable/drag_handle_pill" />
        </LinearLayout>

        <!-- 搜索栏 -->
        <EditText
            android:id="@+id/music_search"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="6dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@color/bg_input"
            android:hint="@string/music_search_hint"
            android:textColor="@color/white"
            android:textColorHint="@color/text_gray_dark"
            android:textSize="13sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:maxLines="1"
            android:singleLine="true" />

        <!-- 列表头部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/music_playlist_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/music_playlist_title"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/music_playlist_selector"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@color/bg_input"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="📂 全部歌曲"
                android:textColor="@color/cyber_cyan"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/music_track_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="0 首"
                android:textColor="@color/text_gray_dark"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 歌曲列表 -->
        <ScrollView
            android:id="@+id/music_playlist_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/music_playlist_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/music_empty_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:gravity="center"
                    android:text="@string/music_empty_hint"
                    android:textColor="@color/text_gray"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:visibility="gone" />
            </FrameLayout>
        </ScrollView>
    </LinearLayout>

</LinearLayout>
