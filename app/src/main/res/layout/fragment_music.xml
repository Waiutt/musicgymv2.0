<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Music Player"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/music_btn_shuffle"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/stats_filter_unselected"
                android:gravity="center"
                android:text="🔀"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/music_mode_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔁 顺序"
                android:textColor="@color/text_gray"
                android:textSize="9sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/music_btn_rescan"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/stats_filter_unselected"
            android:gravity="center"
            android:text="🔄"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 播放器区域 (固定) -->
    <LinearLayout
        android:id="@+id/music_player_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- 专辑封面 -->
        <androidx.cardview.widget.CardView
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="90dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@color/bg_card">

            <ImageView
                android:id="@+id/music_iv_album"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/music_tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未在播放"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/music_tv_artist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="扫描歌曲中..."
            android:textColor="@color/text_gray"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <!-- 进度条 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/music_tv_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/cyber_cyan"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/music_seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:progressTint="@color/cyber_rose"
                android:thumbTint="@color/cyber_rose" />

            <TextView
                android:id="@+id/music_tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_gray_mid"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 控制按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <ImageButton
                android:id="@+id/music_btn_prev"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:scaleX="1.0"
                android:scaleY="1.0"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/music_btn_play"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_play"
                android:scaleX="1.6"
                android:scaleY="1.6"
                app:tint="@color/accent_emerald" />

            <ImageButton
                android:id="@+id/music_btn_next"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                android:scaleX="1.0"
                android:scaleY="1.0"
                app:tint="@color/white" />
        </LinearLayout>
    </LinearLayout>

    <!-- 提拉式播放列表面板 -->
    <FrameLayout
        android:id="@+id/music_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_panel">

        <!-- 拖动把手 (圆润设计) -->
        <LinearLayout
            android:id="@+id/music_drag_handle"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="#00000000">

            <View
                android:layout_width="36dp"
                android:layout_height="5dp"
                android:background="@drawable/drag_handle_pill" />
        </LinearLayout>

        <!-- 搜索栏 -->
        <EditText
            android:id="@+id/music_search"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="32dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@color/bg_input"
            android:hint="🔍 搜索歌曲或歌手..."
            android:textColor="@color/white"
            android:textColorHint="@color/text_gray_dark"
            android:textSize="13sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:maxLines="1"
            android:singleLine="true" />

        <!-- 列表头部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/music_playlist_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="播放列表"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/music_track_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 首"
                android:textColor="@color/text_gray_dark"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 歌曲列表 (可滚动) -->
        <ScrollView
            android:id="@+id/music_playlist_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="52dp"
            android:scrollbars="none">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/music_playlist_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/music_empty_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:gravity="center"
                    android:text="没有找到音乐文件\n请将 MP3 放入 Music 或 Download 文件夹\n然后点击 🔄 重新扫描"
                    android:textColor="@color/text_gray"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:visibility="gone" />
            </FrameLayout>
        </ScrollView>
    </FrameLayout>

</LinearLayout>
